<?xml version="1.0" encoding="utf-8" ?>
<!-- XSD manual extracted from package NLog.Schema: https://www.nuget.org/packages/NLog.Schema-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd" xsi:schemaLocation="NLog NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true" >

	<variable name="layout" value="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${trim-whitespace:inner=${message}${newline}  ${exception:format=Message}}"/>
	<targets>
		<target xsi:type="File" name="logfile" fileName="logs-${date:format=yyyy.MM}.log" layout="${layout}" maxArchiveFiles="6" />
		<target xsi:type="DebugSystem" name="debug" layout="${layout}" />
	</targets>

	<rules>
		<logger name="*" minlevel="Debug" writeTo="debug" />
		<logger name="*" minlevel="Info" writeTo="logfile" />
	</rules>
</nlog>