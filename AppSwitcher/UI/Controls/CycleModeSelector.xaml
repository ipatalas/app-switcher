<UserControl x:Class="AppSwitcher.UI.Controls.CycleModeSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             d:DesignHeight="100" d:DesignWidth="500">
    <UserControl.Resources>
        <Style x:Key="CycleModeButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal">
        <ui:Button x:Name="NextAppButton"
                   Content="Next App"
                   Click="CycleModeButton_Click"
                   Tag="NextApp"
                   Style="{StaticResource CycleModeButtonStyle}"
                   ToolTipService.ToolTip="Subsequent hotkey will do nothing (or cycle to next app if multiple apps share this key)"/>
        <ui:Button x:Name="HideButton"
                   Content="Hide"
                   Click="CycleModeButton_Click"
                   Tag="Hide"
                   Style="{StaticResource CycleModeButtonStyle}"
                   ToolTipService.ToolTip="Subsequent hotkey will toggle visibility of the application"/>
        <ui:Button x:Name="NextWindowButton"
                   Content="Next Window"
                   Click="CycleModeButton_Click"
                   Tag="NextWindow"
                   Style="{StaticResource CycleModeButtonStyle}"
                   ToolTipService.ToolTip="Subsequent hotkey will toggle between all windows of the application"/>
    </StackPanel>
</UserControl>
