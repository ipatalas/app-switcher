<UserControl x:Class="AppSwitcher.UI.Controls.KeyAssignmentButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
    <ui:Button 
        x:Name="InnerButton"
        Content="{Binding ButtonContent, ElementName=Root}"
        Appearance="{Binding ButtonAppearance, ElementName=Root}"
        Width="35" 
        Padding="1" 
        MinWidth="0"
        Focusable="True"
        Click="Button_Click"
        PreviewKeyDown="Button_PreviewKeyDown"
        LostKeyboardFocus="Button_LostKeyboardFocus" />
</UserControl>
