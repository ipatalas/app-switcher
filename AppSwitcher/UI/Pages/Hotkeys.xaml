<Page x:Class="AppSwitcher.UI.Pages.Hotkeys"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AppSwitcher.UI.Controls"
      xmlns:designTime="clr-namespace:AppSwitcher.UI.ViewModels.DesignTime"
      xmlns:common="clr-namespace:AppSwitcher.UI.ViewModels.Common"
      mc:Ignorable="d"
      Title="Hotkeys"
      ScrollViewer.CanContentScroll="False"
      d:DataContext="{d:DesignInstance designTime:HotkeysViewModelDesignTime, IsDesignTimeCreatable=True}"
      d:DesignWidth="700"
      MinWidth="200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}" x:ClassModifier="internal">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row: section label + Add button -->
        <Grid Grid.Row="0" Margin="2,0,10,10">
            <ui:TextBlock Text="Applications"
                          FontTypography="BodyStrong"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          VerticalAlignment="Center" />

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button x:Name="AddButton"
                           Appearance="Secondary"
                           Height="30"
                           Click="AddButton_Click"
                           ToolTipService.ToolTip="Add application binding">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" Margin="0,0,6,0" />
                        <ui:TextBlock Text="Add" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <Popup x:Name="AddFlyoutPopup"
                       PlacementTarget="{Binding ElementName=AddButton}"
                       Placement="Bottom"
                       HorizontalOffset="-240"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       Opened="AddFlyoutPopup_Opened" >
                    <controls:AddApplicationFlyout x:Name="AddApplicationFlyout" DataContext="{Binding FlyoutViewModel, RelativeSource={RelativeSource AncestorType=Page}}"></controls:AddApplicationFlyout>
                </Popup>
            </StackPanel>
        </Grid>

        <!-- Applications list -->
        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding State.HasNoApplications}" Value="True" />
                                <Condition Binding="{Binding State.HasDynamicApplications}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel>
                <ui:ListView
                    x:Name="ApplicationsList"
                             ItemsSource="{Binding State.Applications, Mode=OneWay}"
                             UseLayoutRounding="True"
                             ScrollViewer.CanContentScroll="False"
                             Grid.IsSharedSizeScope="True">
                    <ui:ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ui:ListView.ItemContainerStyle>
                    <ui:ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type common:ApplicationShortcutViewModel}">
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                <Setter Property="BorderThickness" Value="6,0,0,0" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource ValidationStripeBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ui:CardExpander>
                                <ui:CardExpander.Header>
                                    <Grid UseLayoutRounding="True" HorizontalAlignment="Stretch" ShowGridLines="False" Grid.IsSharedSizeScope="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45" SharedSizeGroup="Col1" />
                                            <ColumnDefinition Width="30" SharedSizeGroup="Col2" />
                                            <ColumnDefinition Width="*" MinWidth="200" />
                                            <ColumnDefinition Width="150" SharedSizeGroup="Col4" />
                                        </Grid.ColumnDefinitions>

                                        <controls:KeyAssignmentButton Grid.Column="0" Key="{Binding Key}" />

                                        <Image Grid.Column="1" Source="{Binding ProcessIcon}" Width="24" Height="24" HorizontalAlignment="Left" />

                                        <ui:TextBlock
                                            Grid.Column="2"
                                            Text="{Binding DisplayName}"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,20,0">

                                            <ui:SymbolIcon Symbol="Warning24"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"
                                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                           ToolTipService.InitialShowDelay="300">
                                                <ui:SymbolIcon.ToolTip>
                                                    <ToolTip MaxWidth="500" HasDropShadow="True">
                                                        <TextBlock Text="{Binding ValidationError}"
                                                                   TextWrapping="Wrap" />
                                                    </ToolTip>
                                                </ui:SymbolIcon.ToolTip>
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Hidden" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>

                                            <ui:Button Command="{Binding DataContext.RemoveApplicationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="{ui:ThemeResource SystemFillColorCriticalBrush}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                                <ui:SymbolIcon Symbol="Delete24" />
                                            </ui:Button>

                                        </StackPanel>
                                    </Grid>
                                </ui:CardExpander.Header>
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ui:TextBlock Grid.Row="0" Grid.Column="0"
                                                  Text="When focused:"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                    <controls:CycleModeSelector Grid.Row="0" Grid.Column="1"
                                                                Margin="10,0,0,0"
                                                                SelectedCycleMode="{Binding CycleMode}"
                                                                HorizontalAlignment="Left" />

                                    <ui:TextBlock Grid.Row="1" Grid.Column="0"
                                                  Text="When not running:"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  Margin="0,4,0,0"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                    <StackPanel Grid.Row="1" Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <ui:ToggleSwitch Margin="12,0,0,0"
                                                         OffContent="Don't start"
                                                         OnContent="Start"
                                                         IsChecked="{Binding StartIfNotRunning}" />
                                    </StackPanel>
                                </Grid>
                            </ui:CardExpander>
                            </Border>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>

                <!-- Dynamic apps section -->
                <StackPanel Margin="0,16,0,0"
                            Visibility="{Binding State.HasDynamicApplications, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <ui:TextBlock Text="Dynamic bindings"
                                  FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Margin="2,0,0,6" />

                    <ItemsControl
                        ItemsSource="{Binding State.DynamicApplications, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12, 6"
                                        Margin="0,0,0,2">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" MinWidth="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                CornerRadius="4"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <ui:TextBlock
                                                Text="{Binding KeyLetter}"
                                                FontWeight="SemiBold"
                                                FontSize="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Border>

                                        <Image Grid.Column="1"
                                               Source="{Binding ProcessIcon}"
                                               Width="18" Height="18"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center" />

                                        <ui:TextBlock
                                            Grid.Column="2"
                                            Text="{Binding DisplayName}"
                                            FontSize="13"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />

                                        <ui:Button
                                            Grid.Column="3"
                                            Appearance="Secondary"
                                            Height="26"
                                            Width="26"
                                            Padding="0"
                                            ToolTipService.ToolTip="Pin as static binding"
                                            Command="{Binding DataContext.PinApplicationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Pin20" FontSize="14" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state: shown when Applications list is empty and no dynamic apps -->
        <Border Grid.Row="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding State.HasNoApplications}" Value="True" />
                                <Condition Binding="{Binding State.HasDynamicApplications}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">
                <ui:SymbolIcon Symbol="AppsList24"
                               FontSize="64"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Margin="0,0,0,16" />
                <ui:TextBlock Text="No applications configured"
                              FontTypography="BodyStrong"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Margin="0,0,0,8" />
                <ui:TextBlock Text="Add an application and assign a key. Press your configured modifier key, then that key to instantly switch to that application."
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              TextWrapping="Wrap"
                              MaxWidth="320"
                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                              Margin="0,0,0,20" />
                <ui:Button x:Name="EmptyStateAddButton"
                           Appearance="Primary"
                           HorizontalAlignment="Center"
                           Click="AddButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" Margin="0,0,6,0" />
                        <ui:TextBlock Text="Add application" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
