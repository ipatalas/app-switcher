<Page x:Class="AppSwitcher.UI.Pages.General"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AppSwitcher.UI.Controls"
      xmlns:designTime="clr-namespace:AppSwitcher.UI.ViewModels.DesignTime"
      mc:Ignorable="d"
      Title="General"
      ScrollViewer.CanContentScroll="False"
      d:DataContext="{d:DesignInstance designTime:SettingsViewModelDesignTime, IsDesignTimeCreatable=True}"
      d:DesignWidth="700"
      MinWidth="200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}" x:ClassModifier="internal">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,5,0,20">

            <!-- Appearance -->
            <ui:TextBlock Text="Appearance"
                          FontTypography="BodyStrong"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,7" />

            <ui:CardControl Margin="0,8,0,10"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon PaintBrush24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Theme"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Choose the application color theme."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ComboBox ItemsSource="{Binding AvailableThemes, Mode=OneTime}"
                              SelectedValue="{Binding Theme, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              MinWidth="180" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <!-- Modifier Key -->
            <ui:TextBlock Text="Modifier Key"
                          FontTypography="BodyStrong"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,8" />

            <ui:Card Margin="0,0,0,10" Padding="12,12,12,12">
                <controls:ModifierKeySelector SelectedModifier="{Binding ModifierKey, Mode=TwoWay}" />
            </ui:Card>

            <!-- Behavior -->
            <ui:TextBlock Text="Behavior"
                          FontTypography="BodyStrong"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,8" />

            <ui:CardControl Margin="0,0,0,4"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Timer24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Modifier idle timeout"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Resets stuck modifier state if the key-up event is blocked by the switched-to app. Increase if you notice unintended switches after releasing the modifier key. Set to 0 to disable."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:NumberBox Value="{Binding ModifierIdleTimeoutMs, Mode=TwoWay}"
                                      Minimum="0"
                                      PlaceholderText="0"
                                      AcceptsExpression="False"
                                      PreviewTextInput="ModifierIdleTimeout_OnPreviewTextInput"
                                      HorizontalContentAlignment="Right"
                                      SpinButtonPlacementMode="Compact"
                                      Width="100"
                                      SmallChange="100"
                                      LargeChange="1000" />
                        <TextBlock Text="ms"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Sparkle24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Pulse border effect"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Briefly highlights the window border with a gold pulse when focusing new window. Requires Windows 11 (build 22000+)."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding PulseBorderEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsPulseBorderSupported}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
