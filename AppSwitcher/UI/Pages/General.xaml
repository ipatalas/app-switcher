<Page x:Class="AppSwitcher.UI.Pages.General"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AppSwitcher.UI.Controls"
      xmlns:designTime="clr-namespace:AppSwitcher.UI.ViewModels.DesignTime"
      mc:Ignorable="d"
      Title="General"
      ScrollViewer.CanContentScroll="False"
      d:DataContext="{d:DesignInstance designTime:SettingsViewModelDesignTime, IsDesignTimeCreatable=True}"
      d:DesignWidth="700"
      MinWidth="200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}" x:ClassModifier="internal">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,5,0,20">

            <!-- Appearance -->
            <ui:TextBlock Text="Appearance"
                          FontTypography="BodyStrong"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,7" />

            <ui:CardControl Margin="0,8,0,10"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon PaintBrush24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Theme"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Choose the application color theme."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ComboBox ItemsSource="{Binding AvailableThemes, Mode=OneTime}"
                              SelectedValue="{Binding Theme, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              MinWidth="180" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <!-- Modifier Key -->
            <DockPanel Margin="2,0,0,8">
                <ui:HyperlinkButton DockPanel.Dock="Right"
                                    Content="Learn more"
                                    NavigateUri="https://app-switcher.com/choosing-modifier/"
                                    Padding="0"
                                    FontSize="12"
                                    VerticalAlignment="Center" />
                <ui:TextBlock Text="Modifier Key"
                              FontTypography="BodyStrong"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center" />
            </DockPanel>

            <ui:Card Margin="0,0,0,10" Padding="12,12,12,12">
                <controls:ModifierKeySelector SelectedModifier="{Binding ModifierKey, Mode=TwoWay}" />
            </ui:Card>

            <!-- Behavior -->
            <ui:TextBlock Text="Behavior"
                          FontTypography="BodyStrong"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,8" />

            <ui:CardControl Margin="0,0,0,4"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon WindowNew24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Launch at startup"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Start AppSwitcher automatically when Windows boots"
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,4"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Flash24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Dynamic Mode"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Automatically assigns hotkey letters to running apps based on their name. Letters already assigned to a static shortcut are not affected."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding DynamicModeEnabled, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Sparkle24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Pulse border effect"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Briefly highlights the window border with a gold pulse when focusing new window. Requires Windows 11 (build 22000+)."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding PulseBorderEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsPulseBorderSupported}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Margin="0,4,0,0"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Eye24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Peek mode"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Hold the modifier key to switch to an app, then release to automatically return to your previous window."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding PeekEnabled, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
