<Page x:Class="AppSwitcher.UI.Pages.Stats"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:designTime="clr-namespace:AppSwitcher.UI.ViewModels.DesignTime"
      xmlns:vm="clr-namespace:AppSwitcher.UI.ViewModels"
      mc:Ignorable="d"
      Title="Stats"
      ScrollViewer.CanContentScroll="False"
      d:DataContext="{d:DesignInstance designTime:StatsSettingsViewModelDesignTime, IsDesignTimeCreatable=True}"
      d:DesignWidth="700"
      MinWidth="200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}" x:ClassModifier="internal">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="HeroValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="HeroLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="HeaderTotal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="NerdLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="NerdValue" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,5,0,20">

            <!-- Page header -->
            <Grid Margin="2,0,0,7">
                <ui:TextBlock Text="Statistics"
                              FontTypography="BodyStrong"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center" />
                <ui:ProgressRing Width="18" Height="18"
                              HorizontalAlignment="Right"
                              IsIndeterminate="True"
                              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <!-- Stats collection toggle -->
            <ui:CardControl Margin="0,0,0,16"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon DataHistogram24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Collect usage statistics"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      TextWrapping="WrapWithOverflow">
                            Track which apps you switch to and how often. Data is stored locally and <Bold>never</Bold> leaves your device.
                        </ui:TextBlock>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding State.StatsEnabled, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- Hero row: 3 equal cards                                        -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <UniformGrid Columns="3" Margin="0,0,0,16">

                <!-- Life Gained -->
                <ui:Card Margin="0,0,6,0" Padding="16">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="History24"
                                       FontSize="20"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource SystemAccentColorBrush}" />
                        <TextBlock Text="{Binding LifeGained}"
                                   Style="{StaticResource HeroValue}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Life gained back"
                                   Style="{StaticResource HeroLabel}" />
                    </StackPanel>
                </ui:Card>

                <!-- Productivity Streak -->
                <ui:Card Margin="3,0,3,0" Padding="16">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Fire24"
                                       FontSize="20"
                                       HorizontalAlignment="Left"
                                       Foreground="#FF5722" />
                        <TextBlock Style="{StaticResource HeroValue}" Margin="0,8,0,0">
                            <Run Text="{Binding TeleportStreak, Mode=OneWay}" />
                            <Run Text=" Days" />
                        </TextBlock>
                        <TextBlock Text="Productivity streak"
                                   Style="{StaticResource HeroLabel}" />
                    </StackPanel>
                </ui:Card>

                <!-- Muscle Memory Index -->
                <ui:Card Margin="6,0,0,0" Padding="16">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Trophy24"
                                       FontSize="20"
                                       HorizontalAlignment="Left"
                                       Foreground="#FFD700" />
                        <TextBlock Text="{Binding MuscleMemoGrade}"
                                   Style="{StaticResource HeroValue}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Muscle Memory Index"
                                   Style="{StaticResource HeroLabel}" />
                    </StackPanel>
                </ui:Card>

            </UniformGrid>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- Main two-column grid                                           -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <!-- ─── Left column ─────────────────────────────────────────── -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <!-- Most Used Apps -->
                    <ui:Card Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="MOST USED APPS"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,12" />

                            <!-- Podium: top 3 apps -->
                            <ItemsControl ItemsSource="{Binding Podium}"
                                          Visibility="{Binding HasPodiumData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AppStatEntry}">
                                        <StackPanel Margin="0,0,28,0" Width="56">
                                            <Image Source="{Binding Icon}"
                                                   Width="40" Height="40"
                                                   HorizontalAlignment="Left"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                            <TextBlock Text="{Binding Switches, StringFormat={}{0:N0}}"
                                                       FontWeight="Bold"
                                                       FontSize="13"
                                                       Margin="0,6,0,0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="56" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <TextBlock Text="Start using AppSwitcher to see your most switched apps."
                                       FontSize="12"
                                       Foreground="#999999"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPodiumData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ui:Card>

                    <!-- Maintenance card -->
                    <ui:Card Padding="16" Margin="0,0,0,12">
                        <ui:Card.Style>
                            <Style TargetType="ui:Card">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMaintenanceHealthy}" Value="False">
                                        <Setter Property="Background" Value="#FFF9F0" />
                                        <Setter Property="BorderBrush" Value="#FFE4CC" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMaintenanceHealthy}" Value="True">
                                        <Setter Property="Background" Value="#F0FFF4" />
                                        <Setter Property="BorderBrush" Value="#C6F6D5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Card.Style>

                        <StackPanel>
                        <!-- Healthy state -->
                        <Grid Visibility="{Binding IsMaintenanceHealthy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="CheckmarkCircle24"
                                           FontSize="22"
                                           Foreground="#228B22"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="Your layout is fully optimized. No stale shortcuts found."
                                       FontSize="13"
                                       Foreground="#228B22"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <!-- Warning state -->
                        <Grid Visibility="{Binding IsMaintenanceWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
                                   Source="{Binding FirstStaleShortcut.Icon}"
                                   Width="32" Height="32"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="MAINTENANCE"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#D47500" />
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding FirstStaleShortcut.DisplayName, Mode=OneWay}" />
                                    <Run Text=" shortcut hasn't been used in 30 days." />
                                </TextBlock>
                            </StackPanel>

                            <ui:Button Grid.Column="2"
                                       Appearance="Secondary"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Command="{Binding RemoveStaleShortcutCommand}"
                                       CommandParameter="{Binding FirstStaleShortcut}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Wand24"
                                                   Margin="0,0,6,0"
                                                   FontSize="14" />
                                    <TextBlock VerticalAlignment="Center" FontSize="12">
                                        <Run Text="Remove '" /><Run Text="{Binding FirstStaleShortcut.Letter, Mode=OneWay}" /><Run Text="'" />
                                    </TextBlock>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Habit Tracker -->
                    <ui:Card Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="HABIT TRACKER"
                                           Style="{StaticResource SectionHeader}"
                                           VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                   Foreground="#228B22"
                                                   Margin="0,0,4,0"
                                                   FontSize="14" />
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#228B22"
                                               FontSize="12"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding AltTabSoberStreak, Mode=OneWay}" />
                                        <Run Text=" day sober streak" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Alt-Tab Relapses"
                                           Style="{StaticResource NerdLabel}" />
                                <TextBlock Style="{StaticResource NerdValue}"
                                           Foreground="#E81123">
                                    <Run Text="{Binding AltTabRelapsePct, Mode=OneWay}" />%
                                </TextBlock>
                            </Grid>

                            <ProgressBar Value="{Binding AltTabRelapsePct}"
                                         Height="6"
                                         Foreground="#E81123"
                                         BorderThickness="0"
                                         Background="#EAEAEA"
                                         Margin="0,0,0,10" />

                            <Grid>
                                <TextBlock FontSize="11"
                                           Foreground="#666666"
                                           VerticalAlignment="Center" >
                                    <TextBlock.Text>
                                        <Binding Path="AltTabCuredPct" Mode="OneWay" StringFormat="You're {0}% cured!" />
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="11"
                                           Foreground="#666666"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding WastedKeystrokes, Mode=OneWay}"
                                         FontWeight="Bold"
                                         Foreground="#E81123" />
                                    <Run Text=" wasted keystrokes searching" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                </StackPanel>

                <!-- ─── Right column ────────────────────────────────────────── -->
                <StackPanel Grid.Column="1">

                    <!-- Speed Demon -->
                    <ui:Card Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="SPEED DEMON"
                                           Style="{StaticResource SectionHeader}" />
                                <TextBlock HorizontalAlignment="Right"
                                           Style="{StaticResource HeaderTotal}">
                                    <Run Text="{Binding TotalSwitchCount, Mode=OneWay, StringFormat={}{0:N0}}" />
                                    <Run Text=" switches" />
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Avg Latency"
                                           Style="{StaticResource NerdLabel}" />
                                <TextBlock Text="{Binding AvgLatency}"
                                           Style="{StaticResource NerdValue}" />
                            </Grid>

                            <Grid ToolTip="{Binding PersonalBestTooltip}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Personal Best"
                                               Style="{StaticResource NerdLabel}"
                                               Margin="0,0,6,0" />
                                    <Image Source="{Binding PersonalBestIcon}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </StackPanel>
                                <TextBlock Text="{Binding PersonalBestDisplay}"
                                           Style="{StaticResource NerdValue}"
                                           Foreground="#228B22" />
                            </Grid>

                            <TextBlock Text="{Binding PersonalBestLabel}"
                                       FontSize="10"
                                       Foreground="#999999"
                                       HorizontalAlignment="Right"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Peek Story -->
                    <ui:Card Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="PEEK STORY"
                                           Style="{StaticResource SectionHeader}" />
                                <TextBlock HorizontalAlignment="Right"
                                           Style="{StaticResource HeaderTotal}">
                                    <Run Text="{Binding TotalPeekCount, Mode=OneWay, StringFormat={}{0:N0}}" />
                                    <Run Text=" peeks" />
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Avg Glance"
                                           Style="{StaticResource NerdLabel}" />
                                <TextBlock Text="{Binding AvgGlanceSec}"
                                           Style="{StaticResource NerdValue}" />
                            </Grid>

                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Most Peeked"
                                               Style="{StaticResource NerdLabel}"
                                               Margin="0,0,6,0" />
                                    <Image Source="{Binding MostPeekedApp.Icon}"
                                           Width="14" Height="14"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </StackPanel>
                                <TextBlock Text="{Binding MostPeekedApp.DisplayName, FallbackValue='—'}"
                                           Style="{StaticResource NerdValue}" />
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Discovery Gap -->
                    <ui:Card Padding="16">
                        <StackPanel>
                            <TextBlock Text="DISCOVERY GAP"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,10" />
                            <ProgressBar Value="{Binding StaticPct}"
                                         Height="18"
                                         BorderThickness="0"
                                         Background="#EAEAEA"
                                         Margin="0,0,0,8" />
                            <Grid>
                                <TextBlock FontSize="11"
                                           Foreground="#666666">
                                    <Run Text="{Binding StaticPct, Mode=OneWay}" /><Run Text="% Static" />
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="11"
                                           Foreground="#666666">
                                    <Run Text="{Binding DynamicPct, Mode=OneWay}" /><Run Text="% Dynamic" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
