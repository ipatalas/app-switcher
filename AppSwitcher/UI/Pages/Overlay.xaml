<Page x:Class="AppSwitcher.UI.Pages.Overlay"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:designTime="clr-namespace:AppSwitcher.UI.ViewModels.DesignTime"
      mc:Ignorable="d"
      Title="Overlay"
      ScrollViewer.CanContentScroll="False"
      d:DataContext="{d:DesignInstance designTime:SettingsViewModelDesignTime, IsDesignTimeCreatable=True}"
      d:DesignWidth="700"
      MinWidth="200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}" x:ClassModifier="internal">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,5,0,20">

            <ui:TextBlock Text="App Switcher Overlay"
                          FontTypography="BodyStrong"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Margin="2,0,0,7" />

            <ui:CardControl Margin="0,8,0,4"
                            Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon LayerDiagonal20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Show overlay"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Display a floating list of configured apps when the modifier key is held."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding OverlayEnabled, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Timer24}"
                            IsEnabled="{Binding OverlayEnabled}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Show delay"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="How long the modifier key must be held before the overlay appears."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:NumberBox Value="{Binding OverlayShowDelayMs, Mode=TwoWay}"
                                      Minimum="0"
                                      Maximum="5000"
                                      PlaceholderText="1000"
                                      AcceptsExpression="False"
                                      PreviewTextInput="OverlayShowDelay_OnPreviewTextInput"
                                      HorizontalContentAlignment="Right"
                                      SpinButtonPlacementMode="Compact"
                                      Width="100"
                                      SmallChange="100"
                                      LargeChange="500" />
                        <TextBlock Text="ms"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Content>
            </ui:CardControl>

            <ui:CardControl Padding="20,10,20,10"
                            Icon="{ui:SymbolIcon Pin24}"
                            IsEnabled="{Binding OverlayEnabled}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="Keep open while modifier is held"
                                      TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock Appearance="Secondary"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="When enabled, the overlay stays open and refreshes after each app switch until the modifier key is released."
                                      TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch IsChecked="{Binding OverlayKeepOpenWhileModifierHeld, Mode=TwoWay}"
                                     HorizontalContentAlignment="Left"
                                     OffContent="Off"
                                     OnContent="On" />
                </ui:CardControl.Content>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
