<Window x:Class="AppSwitcher.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        xmlns:local="clr-namespace:AppSwitcher"
        xmlns:viewModels="clr-namespace:AppSwitcher.UI.ViewModels"
        mc:Ignorable="d"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Title="AppSwitcher"
        Height="100"
        Width="100"
        Left="-1000"
        Top="-1000"
        Closed="MainWindow_OnClosed"
        d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel, IsDesignTimeCreatable=True}">
    <StackPanel>
        <tray:NotifyIcon MenuOnRightClick="True" Visibility="Visible" FocusOnLeftClick="False" TooltipText="{Binding TrayTooltipText}">
            <tray:NotifyIcon.Menu>
                <ContextMenu Opened="ContextMenu_OnOpened">
                    <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"></MenuItem>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitApplicationCommand}"></MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </StackPanel>
</Window>
