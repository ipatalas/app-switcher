<Window x:Class="AppSwitcher.UI.Windows.AppOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:AppSwitcher.UI.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
        ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        d:DataContext="{d:DesignInstance viewModels:AppOverlayViewModel}">

    <Window.Resources>

        <!-- Shared item template — used for app rows and focused window rows -->
        <DataTemplate x:Key="AppItemTemplate" DataType="{x:Type viewModels:OverlayAppItem}">
            <Border CornerRadius="6" Padding="4,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" >
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource SystemAccentColor}" Opacity="0.1" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Image Grid.Column="0"
                           Source="{Binding Icon}"
                           Width="20"
                           Height="20"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />

                    <!-- Name / window title -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Name}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontSize="13"
                               MaxWidth="280"
                               Padding="0,0,8,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <!-- Elevated indicator — collapsed for non-elevated apps, takes no space -->
                    <ui:SymbolIcon Grid.Column="2"
                                   Symbol="Shield24"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                   ToolTip="Elevated application">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsElevated}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>

                    <!-- Hotkey badge (D1/D2/… for windows, letter key for apps) -->
                    <ui:Button Grid.Column="3"
                               Content="{Binding HotkeyKey}"
                               Appearance="Secondary"
                               Width="26"
                               Height="26"
                               Padding="1"
                               MinWidth="0"
                               IsHitTestVisible="False"
                               Focusable="False"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <!-- Shadow clearance — gives DropShadowEffect room to render outside the card bounds -->
    <Border Padding="16">

        <!-- Floating card container -->
        <Border x:Name="CardBorder"
                CornerRadius="12"
                Padding="16"
                MinWidth="240"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Opacity="0.95">
        <StackPanel>

            <!-- Focused app windows section — visible only when a NextWindow app is in the foreground -->
            <StackPanel Margin="0,0,0,16">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowFocusedAppWindows}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding FocusedAppName, StringFormat='{}{0} windows'}"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <ItemsControl ItemsSource="{Binding FocusedAppWindows}"
                              ItemTemplate="{StaticResource AppItemTemplate}" />
            </StackPanel>

            <!-- Running apps section -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Running apps"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <ItemsControl ItemsSource="{Binding RunningApps}"
                              ItemTemplate="{StaticResource AppItemTemplate}" />

                <!-- Empty state — visible when HasRunningApps is False -->
                <TextBlock Text="No running apps"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Opacity="0.5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowRunningApps}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Launchable apps section -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowLaunchableApps}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Launchable apps"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <ItemsControl ItemsSource="{Binding LaunchableApps}"
                              ItemTemplate="{StaticResource AppItemTemplate}" />
            </StackPanel>

            <!-- Dynamic apps section -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowDynamicApps}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Dynamic apps"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="0,8,0,6"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <ItemsControl ItemsSource="{Binding DynamicApps}"
                              ItemTemplate="{StaticResource AppItemTemplate}" />
            </StackPanel>

        </StackPanel>
        </Border>

    </Border>
</Window>
